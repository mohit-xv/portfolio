---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/sections/Nav.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Button from '../../components/ui/Button.astro';
import Footer from '../../components/sections/Footer.astro';

const lifecycle = [
  {
    command: 'terraform apply',
    action: 'Provision Lambda, API Gateway, DynamoDB, EventBridge',
    duration: '~45 s',
    cost: '₹0',
  },
  {
    command: 'POST /screen',
    action: 'Lambda fetches NSE/BSE data, screens against criteria',
    duration: '400 ms avg',
    cost: '₹0.001',
  },
  {
    command: 'GET /results',
    action: 'Return JSON results from DynamoDB cache',
    duration: '< 50 ms',
    cost: '₹0.001',
  },
  {
    command: 'terraform destroy',
    action: 'Tear down all resources — no idle cost accumulates',
    duration: '~30 s',
    cost: '₹0',
  },
];
---

<Base
  title="Exhibit II — Stock Screener"
  description="Case study: on-demand stock screener — terraform apply to run it, terraform destroy when done. 400ms scans at ₹0.002 per run."
>
  <Nav />
  <main>

    <!-- Header -->
    <section class="case-hero section">
      <div class="container">
        <Eyebrow>Exhibit No. II</Eyebrow>
        <h1 class="case-hero__heading">
          Stock Screener
        </h1>
        <p class="case-hero__role">On-demand Infrastructure · Python · FinOps</p>

        <!-- The thesis -->
        <div class="screener-thesis">
          <p class="screener-thesis__quote">
            "Not-live is the thesis: idle compute is the disease being cured."
          </p>
          <p class="screener-thesis__note">
            This project has no always-on server. No "coming soon" dashboard.
            It runs when called and is destroyed when done.
          </p>
        </div>
      </div>
    </section>

    <!-- Metrics -->
    <section class="case-summary section">
      <div class="container">
        <div class="case-meta-grid">
          <div class="case-meta-item">
            <p class="case-meta-label">Scan speed</p>
            <p class="case-meta-value case-meta-value--highlight">400 ms</p>
          </div>
          <div class="case-meta-item">
            <p class="case-meta-label">Cost per run</p>
            <p class="case-meta-value case-meta-value--gold">₹0.002</p>
          </div>
          <div class="case-meta-item">
            <p class="case-meta-label">Idle cost</p>
            <p class="case-meta-value case-meta-value--gold">₹0.00</p>
          </div>
          <div class="case-meta-item">
            <p class="case-meta-label">Stack</p>
            <p class="case-meta-value">Python 3.12 · Lambda · DynamoDB · Terraform</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section class="case-section section">
      <div class="container">
        <div class="case-content">
          <h2 class="case-section__heading">The Problem</h2>
          <div class="prose">
            <p>
              Most retail stock screeners run a dedicated server 24/7 for a workload
              that executes for seconds per day. The compute-to-value ratio is terrible.
              A screener that fetches NSE/BSE data, applies fundamental and technical filters,
              and returns a ranked list needs <strong>400 milliseconds of Lambda time</strong>,
              not a ₹2,000/month EC2 instance.
            </p>
            <p>
              The secondary goal was methodological: design a project that fully demonstrates
              the on-demand infrastructure pattern. <code>terraform apply</code> provisions
              everything. The screener runs. <code>terraform destroy</code> removes it all.
              The receipt is the infrastructure itself.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Lifecycle -->
    <section class="case-section section">
      <div class="container">
        <div class="case-content">
          <h2 class="case-section__heading">Run Lifecycle</h2>
          <p class="case-arch-note">
            The entire infrastructure exists only when needed.
            Each row is one phase of a screening session.
          </p>

          <div class="lifecycle-table">
            {lifecycle.map((step, i) => (
              <div class="lifecycle-row">
                <span class="lifecycle-row__num">0{i + 1}</span>
                <code class="lifecycle-row__cmd">{step.command}</code>
                <span class="lifecycle-row__action">{step.action}</span>
                <span class="lifecycle-row__duration">{step.duration}</span>
                <span class="lifecycle-row__cost">{step.cost}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture + decisions -->
    <section class="case-section section">
      <div class="container">
        <div class="case-content">
          <h2 class="case-section__heading">Architecture &amp; Decisions</h2>
          <div class="prose">
            <h3>Lambda as the compute unit</h3>
            <p>
              The screener logic is a single Python 3.12 Lambda function. It fetches
              symbol lists and price data from public NSE/BSE endpoints, applies
              filter criteria (P/E ratio, 52-week relative strength, volume profile),
              and writes ranked results to DynamoDB. Cold start adds ~200ms on the
              first invocation; subsequent calls hit the provisioned container.
              Total wall time: 400ms average.
            </p>

            <h3>DynamoDB as the results store</h3>
            <p>
              Screening results are cached in DynamoDB with a TTL of 24 hours.
              A <code>GET /results</code> call returns cached data in under 50ms,
              bypassing the Lambda entirely for the same day's results.
              DynamoDB on-demand mode: no provisioned capacity, no idle cost.
            </p>

            <h3>No persistent API Gateway stage</h3>
            <p>
              The API Gateway stage is torn down after a session.
              Re-provisioning via <code>terraform apply</code> takes 45 seconds.
              This is an acceptable trade-off: the screener is used at most once
              per day, not as a real-time service.
            </p>

            <h3>Cost per run — the maths</h3>
            <p>
              Lambda: 400ms × 512MB × 1 invocation = 0.0000000833 GB-seconds.
              At AWS Lambda pricing, this rounds to approximately ₹0.0007.
              DynamoDB write: 1 WCU × ~20 items = ₹0.001.
              API Gateway: ₹0.0003. Total: <strong>₹0.002 per screening session</strong>.
            </p>

            <h3>Demo clip</h3>
            <p>
              A 30-second terminal recording showing the full lifecycle — apply,
              screen, results, destroy — is hosted on GitHub (Phase 6 deliverable).
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- No fake live badge -->
    <section class="case-section section">
      <div class="container">
        <div class="case-content">
          <div class="screener-status">
            <p class="screener-status__line">
              This project is not running right now.
            </p>
            <p class="screener-status__sub">
              That's the point. No fake "live" badge. If you want to run it,
              clone the repo, configure AWS credentials, and <code>terraform apply</code>.
              It will cost you ₹0.002.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Links -->
    <section class="case-section section">
      <div class="container">
        <div class="case-links">
          <Button href="https://github.com/mohit-xv" variant="ghost" external>
            View on GitHub
          </Button>
          <Button href="/work/this-website" variant="text">
            ← Exhibit I
          </Button>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>
  .case-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--bone);
    margin-top: var(--space-4);
  }

  .case-hero__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    color: color-mix(in srgb, var(--bone) 45%, transparent);
    margin-top: var(--space-3);
    text-transform: uppercase;
  }

  /* Thesis block */
  .screener-thesis {
    margin-top: var(--space-16);
    padding: var(--space-8) var(--space-10);
    border-left: 3px solid var(--gold);
    max-width: 560px;
  }

  .screener-thesis__quote {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 300;
    color: var(--bone);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-4);
  }

  .screener-thesis__note {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--bone) 55%, transparent);
    line-height: var(--leading-normal);
  }

  /* Meta grid — reused from this-website styles */
  .case-meta-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4) var(--space-8);
    padding: var(--space-8) 0;
    border-top: 1px solid color-mix(in srgb, var(--gold) 12%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 12%, transparent);
  }

  .case-meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: var(--space-2);
  }

  .case-meta-value {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--bone);
    line-height: var(--leading-normal);
  }

  .case-meta-value--gold {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--gold-bright);
  }

  .case-meta-value--highlight {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--bone);
  }

  /* Content section */
  .case-content {
    max-width: var(--max-w-prose);
  }

  .case-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    color: var(--bone);
    margin-bottom: var(--space-8);
  }

  .case-arch-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: color-mix(in srgb, var(--bone) 35%, transparent);
    margin-bottom: var(--space-8);
    max-width: 60ch;
  }

  /* Lifecycle table */
  .lifecycle-table {
    display: flex;
    flex-direction: column;
    border-top: 1px solid color-mix(in srgb, var(--gold) 12%, transparent);
  }

  .lifecycle-row {
    display: grid;
    grid-template-columns: 2rem 180px 1fr 80px 60px;
    gap: var(--space-4) var(--space-6);
    align-items: center;
    padding: var(--space-5) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 8%, transparent);
  }

  .lifecycle-row__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--gold);
  }

  .lifecycle-row__cmd {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--gold-bright);
    background: var(--smoke);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .lifecycle-row__action {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--bone) 70%, transparent);
  }

  .lifecycle-row__duration {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--bone);
    text-align: right;
  }

  .lifecycle-row__cost {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--gold);
    text-align: right;
  }

  /* "Not running" status */
  .screener-status {
    padding: var(--space-8) var(--space-10);
    background: var(--smoke);
    border: 1px solid color-mix(in srgb, var(--oxblood) 30%, transparent);
    border-radius: var(--radius-sm);
    max-width: 560px;
  }

  .screener-status__line {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    color: var(--bone);
    margin-bottom: var(--space-3);
  }

  .screener-status__sub {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--bone) 55%, transparent);
    line-height: var(--leading-normal);
  }

  .screener-status__sub code {
    font-family: var(--font-mono);
    color: var(--gold-bright);
    background: color-mix(in srgb, var(--gold) 10%, var(--smoke));
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .case-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    padding-top: var(--space-8);
    border-top: 1px solid color-mix(in srgb, var(--gold) 12%, transparent);
  }

  @media (max-width: 768px) {
    .case-meta-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .lifecycle-row {
      grid-template-columns: 2rem 1fr auto;
      grid-template-rows: auto auto;
    }
    .lifecycle-row__cmd {
      grid-column: 2;
      grid-row: 1;
    }
    .lifecycle-row__action {
      grid-column: 2 / -1;
      grid-row: 2;
      font-size: var(--text-xs);
    }
    .lifecycle-row__duration {
      grid-column: 3;
      grid-row: 1;
    }
    .lifecycle-row__cost {
      display: none;
    }
    .case-hero__heading {
      font-size: clamp(2.5rem, 12vw, 5rem);
    }
  }
</style>
