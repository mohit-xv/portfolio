---
import Base from '../layouts/Base.astro';
import Nav from '../components/sections/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import TheIndex from '../components/sections/TheIndex.astro';
import LaurelWall from '../components/sections/LaurelWall.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
import Footer from '../components/sections/Footer.astro';
import ColdOpen from '../components/islands/ColdOpen.tsx';
import FlowingPath from '../components/islands/FlowingPath.tsx';
---

<Base title="Mohit Singh">
  <!-- Cold open title card — once per session, fires 'cold-open-complete' when done -->
  <ColdOpen client:load />
  <!-- Full-page cinematic gold ribbon — fixed overlay, draws on scroll -->
  <FlowingPath client:load />
  <Nav />
  <main>
    <Hero />
    <SelectedWork />
    <TheIndex />
    <LaurelWall />
    <ContactCTA />
  </main>
  <Footer />
</Base>
