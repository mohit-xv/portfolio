---
import Base from '../layouts/Base.astro';
import Nav from '../components/sections/Nav.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Button from '../components/ui/Button.astro';
import Footer from '../components/sections/Footer.astro';
import ContactForm from '../components/islands/ContactForm.tsx';
---

<Base
  title="Contact"
  description="Get in touch with Mohit Singh — cloud cost optimisation, DevOps roles, or your AWS bill."
>
  <Nav />
  <main class="contact-page">

    <section class="contact-hero section">
      <div class="container">
        <Eyebrow>Get in touch</Eyebrow>
        <h1 class="contact-hero__heading">
          Start with a message.
        </h1>
        <p class="contact-hero__sub">
          Replies within 48 hours. No sales deck, no discovery call.
          Just a conversation about the problem.
        </p>
      </div>
    </section>

    <section class="contact-body section">
      <div class="container">
        <div class="contact-layout">

          <!-- Left: form (React island handles submission + success/error state) -->
          <div class="contact-form-wrap">
            <ContactForm client:load />
          </div>

          <!-- Right: contact details -->
          <aside class="contact-details">
            <div class="contact-detail-group">
              <p class="contact-detail-label">Email</p>
              <a
                href="mailto:mohitsinghdl2611@gmail.com"
                class="contact-detail-value contact-detail-value--email"
              >
                mohitsinghdl2611@gmail.com
              </a>
            </div>

            <div class="contact-detail-group">
              <p class="contact-detail-label">Response time</p>
              <p class="contact-detail-value">Within 48 hours</p>
            </div>

            <hr class="divider" />

            <div class="contact-links">
              <Button
                href="https://github.com/mohit-xv"
                variant="text"
                external
              >GitHub</Button>

              <Button
                href="https://www.linkedin.com/in/mohit-xv"
                variant="text"
                external
              >LinkedIn</Button>

              <Button
                href="https://www.credly.com/users/mohit-singh"
                variant="text"
                external
              >Credly</Button>

              {/* TODO: drop resume.pdf into site/public/ and this link becomes live */}
              <Button
                href="/resume.pdf"
                variant="ghost"
                download="Mohit-Singh-Resume.pdf"
              >Download CV</Button>
            </div>

            <p class="contact-note">
              Expensive work doesn't ask for the job.
              It earns the conversation.
            </p>
          </aside>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>
  .contact-hero__heading {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--bone);
    margin-top: var(--space-4);
    max-width: 16ch;
  }

  .contact-hero__sub {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    color: color-mix(in srgb, var(--bone) 60%, transparent);
    margin-top: var(--space-6);
    max-width: 46ch;
    line-height: var(--leading-loose);
  }

  /* Layout: form left, details right */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-24);
    align-items: start;
  }

  /* Form styles live inline in ContactForm.tsx (island); page CSS below
     covers only the static layout and the details column. */

  /* Contact details */
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-top: var(--space-2);
  }

  .contact-detail-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-detail-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--gold);
  }

  .contact-detail-value {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    color: var(--bone);
  }

  .contact-detail-value--email {
    text-decoration: none;
    text-underline-offset: 3px;
    text-decoration-color: var(--gold);
    transition: color var(--dur-fast) var(--ease-expo);
    word-break: break-all;
  }

  .contact-detail-value--email:hover {
    color: var(--gold-bright);
    text-decoration: underline;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .contact-note {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-style: italic;
    color: color-mix(in srgb, var(--bone) 40%, transparent);
    line-height: var(--leading-snug);
    border-left: 2px solid color-mix(in srgb, var(--gold) 30%, transparent);
    padding-left: var(--space-5);
    margin-top: var(--space-4);
  }

  /* Mobile */
  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: var(--space-16);
    }
    .contact-hero__heading {
      font-size: clamp(2.5rem, 12vw, 5rem);
    }
    .contact-details {
      order: -1;
    }
  }
</style>
