---
/**
 * FlowingPath — cinematic orbital ribbon.
 *
 * Pure CSS, no React, no hydration, zero JS per scroll frame.
 * CSS scroll-driven animation (animation-timeline: scroll) runs entirely
 * on the browser compositor thread — the spring lag is gone by design.
 *
 * The ribbon is a section of a massive planetary orbit, so large the viewport
 * shows only the near-right arc sweeping across the page.
 *
 * Starts at dashoffset 0.8 — first 20% already drawn when the user lands
 * (mid-orbit seed). The orbit was already in progress. Scrolling draws the rest.
 *
 * Three layers: outer bloom → mid corona → sharp filament.
 * Bloom blur reduced 22 → 8px (~7.5× cheaper; cost scales with radius²).
 * mix-blend-mode removed from wrapper — it was blocking GPU layer promotion.
 * drop-shadow on the SVG element itself is GPU-native and costs almost nothing.
 *
 * Fallback (< 5% of users, Safari < 18, old Chrome): full path immediately.
 * Reduced motion: full path, no animation.
 */
---

<svg
  id="orbital-ribbon"
  aria-hidden="true"
  viewBox="0 0 1440 900"
  preserveAspectRatio="none"
>
  <!-- Outer bloom — wide diffuse ambience of the orbital glow -->
  <path
    class="orbital bloom"
    d="M 1100,70 C 1500,110 1600,200 1480,340 C 1360,680 0,800 -100,920"
    pathLength="1"
    fill="none"
    stroke="#C0A062"
    stroke-width="52"
    stroke-linecap="round"
  />

  <!-- Mid corona — tighter luminous ring -->
  <path
    class="orbital corona"
    d="M 1100,70 C 1500,110 1600,200 1480,340 C 1360,680 0,800 -100,920"
    pathLength="1"
    fill="none"
    stroke="#C0A062"
    stroke-width="11"
    stroke-linecap="round"
  />

  <!-- Sharp filament — the precise orbital trail -->
  <path
    class="orbital filament"
    d="M 1100,70 C 1500,110 1600,200 1480,340 C 1360,680 0,800 -100,920"
    pathLength="1"
    fill="none"
    stroke="#E3C27D"
    stroke-width="1.5"
    stroke-linecap="round"
  />
</svg>

<style>
  #orbital-ribbon {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
    /* Screen blend — gold luminosity on dark backgrounds */
    mix-blend-mode: screen;
    will-change: transform;
    transform: translateZ(0);
  }

  /* ── Scroll-driven draw ──────────────────────────────────────────────────
     animation-timeline: scroll() runs on the compositor thread.
     Zero JS per frame — perfectly synced to Lenis-smoothed scrollY.

     Starts at dashoffset 0.8 (20% already drawn = mid-orbit seed),
     draws the remaining 80% as you scroll from 5% → 97% page depth.      */
  .orbital {
    stroke-dasharray: 1;
    stroke-dashoffset: 0.8;
    animation: reveal-orbit linear both;
    animation-timeline: scroll(root block);
    animation-range: 5% 97%;
  }

  @keyframes reveal-orbit {
    from { stroke-dashoffset: 0.8; }
    to   { stroke-dashoffset: 0;   }
  }

  /* Layer-specific opacity and blur — original values restored */
  .bloom    { opacity: 0.055; filter: blur(22px); }
  .corona   { opacity: 0.15;  filter: blur(4px);  }
  .filament { opacity: 0.90; }

  /* ── Fallback ─────────────────────────────────────────────────────────────
     Browsers without scroll-driven animation support — show full path.     */
  @supports not (animation-timeline: scroll()) {
    .orbital {
      stroke-dashoffset: 0;
      animation: none;
    }
  }

  /* ── Reduced motion ───────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .orbital {
      stroke-dashoffset: 0;
      animation: none;
    }
  }
</style>
