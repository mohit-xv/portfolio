---
/**
 * CosmicBeams — animated diagonal gold light shafts + sparse star field.
 * Pure Astro component: renders a <canvas> and runs a <script> client-side.
 * No React needed — canvas animation has no state or re-renders.
 *
 * The boot() function is called on first load AND on every astro:page-load
 * event so the animation survives Astro View Transition page swaps and HMR
 * hot-reloads without manual refreshing.
 */
---

<canvas
  id="cosmic-beams"
  aria-hidden="true"
  style="position:fixed;inset:0;width:100vw;height:100vh;pointer-events:none;z-index:-1;display:block;"
></canvas>

<script>
  (function () {
    // ── Colour constants — mapped to site design tokens ──
    // --gold        #C0A062  →  DEEP  [192, 160,  98]
    // --gold-bright #E3C27D  →  MID   [227, 194, 125]
    //                        →  CORE  [255, 244, 209]  warm cream
    const CORE: [number,number,number] = [255, 244, 209];
    const MID:  [number,number,number] = [227, 194, 125];
    const DEEP: [number,number,number] = [192, 160,  98];

    function c(rgb: [number,number,number], a: number) {
      return `rgba(${rgb[0]},${rgb[1]},${rgb[2]},${a.toFixed(3)})`;
    }

    const LAYERS          = 3;
    const BEAMS_PER_LAYER = 6;

    interface Beam {
      x: number; y: number; width: number; length: number;
      angleDeg: number; speed: number; baseOpacity: number;
      pulse: number; pulseSpeed: number; layer: number;
    }

    interface Star {
      x: number; y: number;
      radius: number; baseOpacity: number;
      pulse: number; pulseSpeed: number;
      tier: 0 | 1 | 2;  // 0=distant cool, 1=medium neutral, 2=bright warm
    }

    // ── Module-level mutable state — reassigned by every boot() call ──────────
    let canvas: HTMLCanvasElement | null = null;
    let ctx: CanvasRenderingContext2D | null = null;
    let beams: Beam[] = [];
    let stars: Star[] = [];
    let raf       = 0;
    let isReduced = false;

    // ── Beam helpers ─────────────────────────────────────────────────────────
    function makeBeam(w: number, h: number, layer: number): Beam {
      const t = layer / LAYERS;
      return {
        x:           Math.random() * w,
        y:           Math.random() * h,
        width:       10 + layer * 8,
        length:      h * 2.4,
        angleDeg:    -30 - Math.random() * 10,
        speed:       0.22 + t * 0.28 + Math.random() * 0.12,
        baseOpacity: 0.09 + t * 0.08 + Math.random() * 0.05,
        pulse:       Math.random() * Math.PI * 2,
        pulseSpeed:  0.007 + Math.random() * 0.010,
        layer,
      };
    }

    function drawBackground(w: number, h: number) {
      // Universe-black: no ambient glow. Gold appears only where beams are.
      ctx!.fillStyle = '#08080C';
      ctx!.fillRect(0, 0, w, h);
    }

    function drawOuter(beam: Beam) {
      const p = beam.baseOpacity * (0.70 + Math.sin(beam.pulse) * 0.38);
      ctx!.save();
      ctx!.translate(beam.x, beam.y);
      ctx!.rotate((beam.angleDeg * Math.PI) / 180);
      const g = ctx!.createLinearGradient(0, 0, 0, beam.length);
      g.addColorStop(0,    c(CORE, 0));
      g.addColorStop(0.15, c(CORE, p * 0.40));
      g.addColorStop(0.42, c(MID,  p * 1.00));
      g.addColorStop(0.55, c(CORE, p * 0.75));
      g.addColorStop(0.80, c(DEEP, p * 0.55));
      g.addColorStop(1,    c(DEEP, 0));
      ctx!.fillStyle = g;
      ctx!.fillRect(-beam.width / 2, 0, beam.width, beam.length);
      ctx!.restore();
    }

    function drawCore(beam: Beam) {
      const p = beam.baseOpacity * (0.70 + Math.sin(beam.pulse) * 0.38);
      ctx!.save();
      ctx!.translate(beam.x, beam.y);
      ctx!.rotate((beam.angleDeg * Math.PI) / 180);
      const g = ctx!.createLinearGradient(0, 0, 0, beam.length);
      g.addColorStop(0,    c(CORE, 0));
      g.addColorStop(0.35, c(CORE, p * 0.65));
      g.addColorStop(0.55, c(CORE, p * 0.65));
      g.addColorStop(1,    c(CORE, 0));
      ctx!.fillStyle = g;
      ctx!.fillRect(-beam.width / 7, 0, beam.width / 3.5, beam.length);
      ctx!.restore();
    }

    // ── Star helpers ─────────────────────────────────────────────────────────
    function makeStars(w: number, h: number) {
      stars = [];

      // Tier 0 — 130 distant field stars: tiny, very faint, cool blue-white
      // Biased slightly toward upper 65% of screen for a natural sky feel
      for (let i = 0; i < 130; i++) {
        const yBias = Math.random() < 0.65
          ? Math.random() * h * 0.70
          : Math.random() * h;
        stars.push({
          x:           Math.random() * w,
          y:           yBias,
          radius:      0.20 + Math.random() * 0.55,
          baseOpacity: 0.030 + Math.random() * 0.130,
          pulse:       Math.random() * Math.PI * 2,
          pulseSpeed:  0.0008 + Math.random() * 0.0022,
          tier:        0,
        });
      }

      // Tier 1 — 48 medium stars: slightly brighter, neutral white, gentle twinkle
      for (let i = 0; i < 48; i++) {
        stars.push({
          x:           Math.random() * w,
          y:           Math.random() * h,
          radius:      0.55 + Math.random() * 0.60,
          baseOpacity: 0.110 + Math.random() * 0.180,
          pulse:       Math.random() * Math.PI * 2,
          pulseSpeed:  0.0012 + Math.random() * 0.0024,
          tier:        1,
        });
      }

      // Tier 2 — 3 bright near stars: warm cream, wide glow halo, diffraction spikes
      for (let i = 0; i < 3; i++) {
        stars.push({
          x:           (0.06 + Math.random() * 0.88) * w,
          y:           (0.03 + Math.random() * 0.75) * h,
          radius:      1.15 + Math.random() * 0.95,
          baseOpacity: 0.52 + Math.random() * 0.34,
          pulse:       Math.random() * Math.PI * 2,
          pulseSpeed:  0.0014 + Math.random() * 0.0016,
          tier:        2,
        });
      }
    }

    // Diffraction spike — the fine cross that appears on bright stars in telescope photos
    function drawSpike(x: number, y: number, len: number, angle: number, opacity: number) {
      ctx!.save();
      ctx!.translate(x, y);
      ctx!.rotate(angle);
      const g = ctx!.createLinearGradient(-len, 0, len, 0);
      g.addColorStop(0,    `rgba(255,248,224,0)`);
      g.addColorStop(0.30, `rgba(255,248,224,${(opacity * 0.22).toFixed(3)})`);
      g.addColorStop(0.50, `rgba(255,252,235,${(opacity * 0.60).toFixed(3)})`);
      g.addColorStop(0.70, `rgba(255,248,224,${(opacity * 0.22).toFixed(3)})`);
      g.addColorStop(1,    `rgba(255,248,224,0)`);
      ctx!.fillStyle = g;
      ctx!.fillRect(-len, -0.6, len * 2, 1.2);
      ctx!.restore();
    }

    function drawStars() {
      for (const s of stars) {
        s.pulse += s.pulseSpeed;
        const opacity = s.baseOpacity * (0.72 + Math.sin(s.pulse) * 0.28);

        if (s.tier === 0) {
          // Tiny cool-blue distant field star — no halo, just the dot
          ctx!.beginPath();
          ctx!.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(200,218,255,${opacity.toFixed(3)})`;
          ctx!.fill();

        } else if (s.tier === 1) {
          // Medium neutral-white star — very faint aura + core dot
          const aura = ctx!.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.radius * 4);
          aura.addColorStop(0, `rgba(240,242,248,${(opacity * 0.20).toFixed(3)})`);
          aura.addColorStop(1, 'rgba(240,242,248,0)');
          ctx!.beginPath();
          ctx!.arc(s.x, s.y, s.radius * 4, 0, Math.PI * 2);
          ctx!.fillStyle = aura;
          ctx!.fill();

          ctx!.beginPath();
          ctx!.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(240,242,248,${opacity.toFixed(3)})`;
          ctx!.fill();

        } else {
          // Tier 2 — bright near star: multi-stop glow halo + diffraction cross + warm core
          const haloR = s.radius * 9;
          const halo  = ctx!.createRadialGradient(s.x, s.y, 0, s.x, s.y, haloR);
          halo.addColorStop(0,    `rgba(255,244,209,${(opacity * 0.45).toFixed(3)})`);
          halo.addColorStop(0.25, `rgba(255,238,192,${(opacity * 0.18).toFixed(3)})`);
          halo.addColorStop(0.55, `rgba(255,228,170,${(opacity * 0.07).toFixed(3)})`);
          halo.addColorStop(1,    'rgba(255,220,150,0)');
          ctx!.beginPath();
          ctx!.arc(s.x, s.y, haloR, 0, Math.PI * 2);
          ctx!.fillStyle = halo;
          ctx!.fill();

          // Diffraction cross — horizontal + vertical + softer 45° diagonals
          const spikeLen = s.radius * 14;
          drawSpike(s.x, s.y, spikeLen,        0,            opacity);
          drawSpike(s.x, s.y, spikeLen,        Math.PI / 2,  opacity);
          drawSpike(s.x, s.y, spikeLen * 0.6,  Math.PI / 4,  opacity * 0.55);
          drawSpike(s.x, s.y, spikeLen * 0.6, -Math.PI / 4,  opacity * 0.55);

          // Bright warm-cream core dot
          ctx!.beginPath();
          ctx!.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(255,252,235,${opacity.toFixed(3)})`;
          ctx!.fill();
        }
      }
    }

    // ── Resize + frame loop ───────────────────────────────────────────────────
    function resize() {
      if (!canvas || !ctx) return;
      const dpr = Math.min(window.devicePixelRatio ?? 1, 2);
      const w   = window.innerWidth;
      const h   = window.innerHeight;
      canvas.width  = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      canvas.style.width  = `${w}px`;
      canvas.style.height = `${h}px`;
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
      beams = [];
      for (let layer = 1; layer <= LAYERS; layer++) {
        for (let i = 0; i < BEAMS_PER_LAYER; i++) {
          beams.push(makeBeam(w, h, layer));
        }
      }
      makeStars(w, h);
      // In reduced-motion mode there is no RAF loop — redraw the static frame
      // so a window resize doesn't leave the canvas permanently blank.
      if (isReduced) { drawBackground(w, h); drawStars(); }
    }

    function frame() {
      if (!canvas || !ctx) return;
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;
      drawBackground(w, h);
      drawStars();

      for (let layer = 1; layer <= LAYERS; layer++) {
        ctx.filter = `blur(${2 + layer * 2}px)`;
        for (const b of beams) {
          if (b.layer !== layer) continue;
          b.y     -= b.speed;
          b.pulse += b.pulseSpeed;
          if (b.y + b.length < 0) { b.y = h + 10; b.x = Math.random() * w; }
          drawOuter(b);
        }
      }

      for (let layer = 1; layer <= LAYERS; layer++) {
        ctx.filter = `blur(${0.5 + layer * 0.4}px)`;
        for (const b of beams) {
          if (b.layer !== layer) continue;
          drawCore(b);
        }
      }

      ctx.filter = 'none';
      raf = requestAnimationFrame(frame);
    }

    // ── boot — safe to call multiple times (cancels previous loop first) ─────
    function boot() {
      // Cancel any running loop and remove the resize handler. We use
      // window.__cosmicResizeFn so that after an HMR module re-evaluation
      // the previous closure's resize reference can still be removed.
      cancelAnimationFrame(raf);
      const prevResize = (window as any).__cosmicResizeFn;
      if (prevResize) window.removeEventListener('resize', prevResize);

      canvas = document.getElementById('cosmic-beams') as HTMLCanvasElement | null;
      if (!canvas) return;
      ctx = canvas.getContext('2d');
      if (!ctx) return;

      isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      resize(); // resize() calls drawBackground+drawStars when isReduced

      if (!isReduced) {
        raf = requestAnimationFrame(frame);
      }

      (window as any).__cosmicResizeFn = resize;
      window.addEventListener('resize', resize, { passive: true });
    }

    // Guard against astro:page-load listener accumulation across HMR
    // re-evaluations. Each new IIFE creates a new boot reference; storing
    // it on window lets us remove the previous one before adding the new one.
    const prevBoot = (window as any).__cosmicBootFn;
    if (prevBoot) document.removeEventListener('astro:page-load', prevBoot);
    (window as any).__cosmicBootFn = boot;
    document.addEventListener('astro:page-load', boot);
    boot();
  })();
</script>
