---
/**
 * CosmicBeams — animated diagonal gold light shafts + sparse star field.
 * Pure Astro component: renders a <canvas> and runs a <script> client-side.
 * No React needed — canvas animation has no state or re-renders.
 *
 * The boot() function is called on first load AND on every astro:page-load
 * event so the animation survives Astro View Transition page swaps and HMR
 * hot-reloads without manual refreshing.
 *
 * ── Rendering: sprite caching ────────────────────────────────────────────────
 * Every gradient and blur is pre-rendered ONCE into offscreen canvases
 * (at boot and on resize). The 60fps frame loop only calls drawImage() on
 * those cached bitmaps with per-frame position/alpha — no gradient creation,
 * no ctx.filter blur, no per-frame rasterization.
 *
 * This is valid because every animated quantity (beam pulse, star twinkle)
 * is a LINEAR alpha multiplier over the layer's colors — so baking the sprite
 * at full intensity and modulating globalAlpha at draw time produces
 * mathematically identical pixels to recomputing the gradients each frame.
 * Visual output is unchanged; per-frame cost drops ~20×.
 */
---

<canvas
  id="cosmic-beams"
  aria-hidden="true"
  style="position:fixed;inset:0;width:100vw;height:100vh;pointer-events:none;z-index:-1;display:block;"
></canvas>

<script>
  (function () {
    // ── Colour constants — mapped to site design tokens ──
    // --gold        #C0A062  →  DEEP  [192, 160,  98]
    // --gold-bright #E3C27D  →  MID   [227, 194, 125]
    //                        →  CORE  [255, 244, 209]  warm cream
    const CORE: [number,number,number] = [255, 244, 209];
    const MID:  [number,number,number] = [227, 194, 125];
    const DEEP: [number,number,number] = [192, 160,  98];

    function c(rgb: [number,number,number], a: number) {
      return `rgba(${rgb[0]},${rgb[1]},${rgb[2]},${a.toFixed(3)})`;
    }

    const LAYERS          = 3;
    const BEAMS_PER_LAYER = 6;

    interface Beam {
      x: number; y: number; width: number; length: number;
      angleDeg: number; speed: number; baseOpacity: number;
      pulse: number; pulseSpeed: number; layer: number;
    }

    interface Star {
      x: number; y: number;
      radius: number; baseOpacity: number;
      pulse: number; pulseSpeed: number;
      tier: 0 | 1 | 2;  // 0=distant cool, 1=medium neutral, 2=bright warm
      // Sprite cache — baked once at creation, drawn with globalAlpha per frame
      sprite: HTMLCanvasElement;
      spriteSize: number; // CSS-px width/height of the sprite's draw box
    }

    interface BeamSprites {
      outer: HTMLCanvasElement;
      core:  HTMLCanvasElement;
      pad:   number;      // CSS-px padding baked around the beam for blur bleed
      width: number;      // beam rect width (CSS px)
      length: number;     // beam rect length (CSS px)
    }

    // Shooting star — lightning-fast meteor with a bright head and fading tail,
    // burning out mid-flight like it hit the atmosphere.
    interface Meteor {
      x: number; y: number;   // head position (CSS px)
      vx: number; vy: number; // velocity (CSS px per second)
      born: number;           // spawn timestamp (ms)
      dur: number;            // lifetime (ms) — it burns out before exiting
      scale: number;          // per-meteor size variation
    }

    // ── Module-level mutable state — reassigned by every boot() call ──────────
    let canvas: HTMLCanvasElement | null = null;
    let ctx: CanvasRenderingContext2D | null = null;
    let beams: Beam[] = [];
    let stars: Star[] = [];
    let beamSprites: BeamSprites[] = [];   // indexed by layer-1
    let bgSprite: HTMLCanvasElement | null = null;
    let meteorSprite: HTMLCanvasElement | null = null;
    let meteors: Meteor[] = [];
    let nextMeteorAt = 0;   // timestamp of the next scheduled spawn (ms)
    let lastNow      = 0;   // previous frame timestamp for dt
    let raf       = 0;
    let isReduced = false;
    let dpr       = 1;
    let lastW     = 0;   // previous viewport size — detects height-only resizes
    let lastH     = 0;   // (mobile URL bar) so the sky isn't re-randomized mid-scroll

    // ── Offscreen helper ──────────────────────────────────────────────────────
    function makeOffscreen(wCss: number, hCss: number): [HTMLCanvasElement, CanvasRenderingContext2D] {
      const cv = document.createElement('canvas');
      cv.width  = Math.max(1, Math.ceil(wCss * dpr));
      cv.height = Math.max(1, Math.ceil(hCss * dpr));
      const cx = cv.getContext('2d')!;
      cx.scale(dpr, dpr);
      return [cv, cx];
    }

    // ── Beam helpers ─────────────────────────────────────────────────────────
    function makeBeam(w: number, h: number, layer: number): Beam {
      const t = layer / LAYERS;
      return {
        x:           Math.random() * w,
        y:           Math.random() * h,
        width:       10 + layer * 8,
        length:      h * 2.4,
        angleDeg:    -30 - Math.random() * 10,
        speed:       0.22 + t * 0.28 + Math.random() * 0.12,
        baseOpacity: 0.09 + t * 0.08 + Math.random() * 0.05,
        pulse:       Math.random() * Math.PI * 2,
        pulseSpeed:  0.007 + Math.random() * 0.010,
        layer,
      };
    }

    /**
     * Bake the two beam sprites (outer glow + bright core) for one layer.
     * Same gradients and blur radii as the original per-frame code, with the
     * pulse alpha factored out (baked at p=1, modulated via globalAlpha).
     */
    function bakeBeamSprites(h: number, layer: number): BeamSprites {
      const width     = 10 + layer * 8;
      const length    = h * 2.4;
      const outerBlur = 2 + layer * 2;
      const coreBlur  = 0.5 + layer * 0.4;
      const pad       = Math.ceil(outerBlur * 3) + 2;

      // Outer glow — original gradient at p=1, original blur baked in
      const [outer, octx] = makeOffscreen(width + pad * 2, length + pad * 2);
      const og = octx.createLinearGradient(0, pad, 0, pad + length);
      og.addColorStop(0,    c(CORE, 0));
      og.addColorStop(0.15, c(CORE, 0.40));
      og.addColorStop(0.42, c(MID,  1.00));
      og.addColorStop(0.55, c(CORE, 0.75));
      og.addColorStop(0.80, c(DEEP, 0.55));
      og.addColorStop(1,    c(DEEP, 0));
      octx.filter = `blur(${outerBlur}px)`;
      octx.fillStyle = og;
      octx.fillRect(pad, pad, width, length);

      // Bright core — original gradient at p=1, original blur baked in
      const [core, cctx] = makeOffscreen(width + pad * 2, length + pad * 2);
      const cg = cctx.createLinearGradient(0, pad, 0, pad + length);
      cg.addColorStop(0,    c(CORE, 0));
      cg.addColorStop(0.35, c(CORE, 0.65));
      cg.addColorStop(0.55, c(CORE, 0.65));
      cg.addColorStop(1,    c(CORE, 0));
      cctx.filter = `blur(${coreBlur}px)`;
      cctx.fillStyle = cg;
      // Original: fillRect(-width/7, 0, width/3.5, length), relative to beam centre.
      // Sprite space: centre is at pad + width/2.
      cctx.fillRect(pad + width / 2 - width / 7, pad, width / 3.5, length);

      return { outer, core, pad, width, length };
    }

    // Draw a beam sprite at the beam's position/rotation with the pulse alpha.
    // p is the same value the original computed inside drawOuter/drawCore.
    function drawBeamSprite(beam: Beam, img: HTMLCanvasElement, sp: BeamSprites) {
      const p = beam.baseOpacity * (0.70 + Math.sin(beam.pulse) * 0.38);
      ctx!.save();
      ctx!.translate(beam.x, beam.y);
      ctx!.rotate((beam.angleDeg * Math.PI) / 180);
      ctx!.globalAlpha = Math.max(0, Math.min(1, p));
      ctx!.drawImage(
        img,
        -sp.width / 2 - sp.pad, -sp.pad,
        sp.width + sp.pad * 2, sp.length + sp.pad * 2,
      );
      ctx!.restore();
    }

    // ── Background — baked once per resize ───────────────────────────────────
    function bakeBackground(w: number, h: number) {
      const [cv, cx] = makeOffscreen(w, h);
      const bg = cx.createLinearGradient(0, 0, 0, h);
      bg.addColorStop(0,   '#0D0B09');
      bg.addColorStop(0.6, '#0F0C08');
      bg.addColorStop(1,   '#120D07');
      cx.fillStyle = bg;
      cx.fillRect(0, 0, w, h);

      // Soft golden glow anchored to the top-LEFT corner, spread along the top
      // edge — reaches toward centre but fades out before it. Elliptical via
      // a vertical scale so it hugs the top like dawn light.
      cx.save();
      cx.scale(1, 0.55);
      const glow = cx.createRadialGradient(0, 0, 0, 0, 0, w * 0.48);
      glow.addColorStop(0,    c(MID, 0.15));
      glow.addColorStop(0.45, c(MID, 0.06));
      glow.addColorStop(1,    c(DEEP, 0));
      cx.fillStyle = glow;
      cx.fillRect(0, 0, w, h * 2);
      cx.restore();

      bgSprite = cv;
    }

    // ── Star sprite baking ────────────────────────────────────────────────────
    // Each sprite is baked at full intensity (opacity=1); the twinkle is applied
    // per frame via globalAlpha. All original alpha stops are linear multiples
    // of opacity, so the result is identical to the per-frame gradient version.

    function drawSpikeInto(cx: CanvasRenderingContext2D, x: number, y: number, len: number, angle: number, alpha: number) {
      cx.save();
      cx.translate(x, y);
      cx.rotate(angle);
      const g = cx.createLinearGradient(-len, 0, len, 0);
      g.addColorStop(0,    `rgba(255,248,224,0)`);
      g.addColorStop(0.30, `rgba(255,248,224,${(alpha * 0.22).toFixed(3)})`);
      g.addColorStop(0.50, `rgba(255,252,235,${(alpha * 0.60).toFixed(3)})`);
      g.addColorStop(0.70, `rgba(255,248,224,${(alpha * 0.22).toFixed(3)})`);
      g.addColorStop(1,    `rgba(255,248,224,0)`);
      cx.fillStyle = g;
      cx.fillRect(-len, -0.6, len * 2, 1.2);
      cx.restore();
    }

    function bakeStarSprite(radius: number, tier: 0 | 1 | 2): [HTMLCanvasElement, number] {
      // Sprite half-extent per tier (matches the largest painted element)
      const half = tier === 0 ? radius + 1
                 : tier === 1 ? radius * 4 + 1
                 :              radius * 14 + 2; // spikes reach radius*14
      const size = half * 2;
      const [cv, cx] = makeOffscreen(size, size);
      const ctr = half;

      if (tier === 0) {
        // Tiny cool-blue distant field star — no halo, just the dot
        cx.beginPath();
        cx.arc(ctr, ctr, radius, 0, Math.PI * 2);
        cx.fillStyle = 'rgba(200,218,255,1)';
        cx.fill();

      } else if (tier === 1) {
        // Medium neutral-white star — very faint aura + core dot
        const aura = cx.createRadialGradient(ctr, ctr, 0, ctr, ctr, radius * 4);
        aura.addColorStop(0, 'rgba(240,242,248,0.20)');
        aura.addColorStop(1, 'rgba(240,242,248,0)');
        cx.beginPath();
        cx.arc(ctr, ctr, radius * 4, 0, Math.PI * 2);
        cx.fillStyle = aura;
        cx.fill();

        cx.beginPath();
        cx.arc(ctr, ctr, radius, 0, Math.PI * 2);
        cx.fillStyle = 'rgba(240,242,248,1)';
        cx.fill();

      } else {
        // Bright near star: multi-stop glow halo + diffraction cross + warm core
        const haloR = radius * 9;
        const halo  = cx.createRadialGradient(ctr, ctr, 0, ctr, ctr, haloR);
        halo.addColorStop(0,    'rgba(255,244,209,0.45)');
        halo.addColorStop(0.25, 'rgba(255,238,192,0.18)');
        halo.addColorStop(0.55, 'rgba(255,228,170,0.07)');
        halo.addColorStop(1,    'rgba(255,220,150,0)');
        cx.beginPath();
        cx.arc(ctr, ctr, haloR, 0, Math.PI * 2);
        cx.fillStyle = halo;
        cx.fill();

        // Diffraction cross — horizontal + vertical + softer 45° diagonals
        const spikeLen = radius * 14;
        drawSpikeInto(cx, ctr, ctr, spikeLen,        0,           1);
        drawSpikeInto(cx, ctr, ctr, spikeLen,        Math.PI / 2, 1);
        drawSpikeInto(cx, ctr, ctr, spikeLen * 0.6,  Math.PI / 4, 0.55);
        drawSpikeInto(cx, ctr, ctr, spikeLen * 0.6, -Math.PI / 4, 0.55);

        // Bright warm-cream core dot
        cx.beginPath();
        cx.arc(ctr, ctr, radius, 0, Math.PI * 2);
        cx.fillStyle = 'rgba(255,252,235,1)';
        cx.fill();
      }

      return [cv, size];
    }

    function makeStar(x: number, y: number, radius: number, baseOpacity: number,
                      pulse: number, pulseSpeed: number, tier: 0 | 1 | 2): Star {
      const [sprite, spriteSize] = bakeStarSprite(radius, tier);
      return { x, y, radius, baseOpacity, pulse, pulseSpeed, tier, sprite, spriteSize };
    }

    function makeStars(w: number, h: number) {
      stars = [];

      // Tier 0 — 130 distant field stars: tiny, very faint, cool blue-white
      // Biased slightly toward upper 65% of screen for a natural sky feel
      for (let i = 0; i < 130; i++) {
        const yBias = Math.random() < 0.65
          ? Math.random() * h * 0.70
          : Math.random() * h;
        stars.push(makeStar(
          Math.random() * w, yBias,
          0.20 + Math.random() * 0.55,
          0.030 + Math.random() * 0.130,
          Math.random() * Math.PI * 2,
          0.0008 + Math.random() * 0.0022,
          0,
        ));
      }

      // Tier 1 — 48 medium stars: slightly brighter, neutral white, gentle twinkle
      for (let i = 0; i < 48; i++) {
        stars.push(makeStar(
          Math.random() * w, Math.random() * h,
          0.55 + Math.random() * 0.60,
          0.110 + Math.random() * 0.180,
          Math.random() * Math.PI * 2,
          0.0012 + Math.random() * 0.0024,
          1,
        ));
      }

      // Tier 2 — 3 bright near stars: warm cream, wide glow halo, diffraction spikes
      for (let i = 0; i < 3; i++) {
        stars.push(makeStar(
          (0.06 + Math.random() * 0.88) * w,
          (0.03 + Math.random() * 0.75) * h,
          1.15 + Math.random() * 0.95,
          0.52 + Math.random() * 0.34,
          Math.random() * Math.PI * 2,
          0.0014 + Math.random() * 0.0016,
          2,
        ));
      }
    }

    function drawStars() {
      for (const s of stars) {
        s.pulse += s.pulseSpeed;
        const opacity = s.baseOpacity * (0.72 + Math.sin(s.pulse) * 0.28);
        const half = s.spriteSize / 2;
        ctx!.globalAlpha = Math.max(0, Math.min(1, opacity));
        ctx!.drawImage(s.sprite, s.x - half, s.y - half, s.spriteSize, s.spriteSize);
      }
      ctx!.globalAlpha = 1;
    }

    // ── Shooting star ─────────────────────────────────────────────────────────
    // Sprite baked once (blurs included); per frame it's one drawImage with
    // translate/rotate/globalAlpha — follows the same caching pattern as beams.

    const METEOR_TAIL = 260; // tail length within the sprite (CSS px)
    const METEOR_H    = 44;  // sprite height (room for the bigger head halo)
    const METEOR_PAD  = 24;  // room beyond the head for its glow

    function bakeMeteorSprite() {
      const [cv, cx] = makeOffscreen(METEOR_TAIL + METEOR_PAD, METEOR_H);
      const cy    = METEOR_H / 2;
      const headX = METEOR_TAIL;

      // Soft golden tail underlayer — slim atmospheric glow along the streak
      const soft = cx.createLinearGradient(0, 0, headX, 0);
      soft.addColorStop(0,    'rgba(192,160,98,0)');
      soft.addColorStop(0.55, 'rgba(227,194,125,0.14)');
      soft.addColorStop(0.85, 'rgba(240,214,150,0.30)');
      soft.addColorStop(1,    'rgba(255,238,190,0.42)');
      cx.filter = 'blur(3px)';
      cx.beginPath();
      cx.moveTo(0, cy);
      cx.lineTo(headX, cy - 2.4);
      cx.lineTo(headX, cy + 2.4);
      cx.closePath();
      cx.fillStyle = soft;
      cx.fill();

      // Sharp tapered golden filament — hair-thin at the tail tip
      const tail = cx.createLinearGradient(0, 0, headX, 0);
      tail.addColorStop(0,    'rgba(227,194,125,0)');
      tail.addColorStop(0.45, 'rgba(227,194,125,0.35)');
      tail.addColorStop(0.85, 'rgba(255,236,190,0.85)');
      tail.addColorStop(1,    'rgba(255,248,220,1)');
      cx.filter = 'blur(0.5px)';
      cx.beginPath();
      cx.moveTo(0, cy);
      cx.lineTo(headX, cy - 0.9);
      cx.lineTo(headX, cy + 0.9);
      cx.closePath();
      cx.fillStyle = tail;
      cx.fill();

      // Head — big white-hot core inside a wide warm-gold halo
      cx.filter = 'none';
      const halo = cx.createRadialGradient(headX, cy, 0, headX, cy, 18);
      halo.addColorStop(0,    'rgba(255,252,240,1)');
      halo.addColorStop(0.18, 'rgba(255,244,209,0.80)');
      halo.addColorStop(0.45, 'rgba(240,208,140,0.32)');
      halo.addColorStop(1,    'rgba(210,175,110,0)');
      cx.beginPath();
      cx.arc(headX, cy, 18, 0, Math.PI * 2);
      cx.fillStyle = halo;
      cx.fill();

      meteorSprite = cv;
    }

    function scheduleNextMeteor(now: number) {
      // Long random gaps (6–16s) keep it rare; a ~15% chance of a quick
      // follow-up gives an occasional two-meteor moment. The hard cap of 2
      // concurrent is enforced at spawn time.
      const quick = Math.random() < 0.15;
      nextMeteorAt = now + (quick ? 400 + Math.random() * 800
                                  : 6000 + Math.random() * 10000);
    }

    function spawnMeteor(w: number, h: number, now: number) {
      const ltr   = Math.random() < 0.6;                        // most travel left→right
      const angle = (16 + Math.random() * 22) * Math.PI / 180;  // shallow descent
      const speed = 1000 + Math.random() * 700;                 // lightning-fast (px/s)
      meteors.push({
        x:     ltr ? Math.random() * w * 0.55 : w * 0.45 + Math.random() * w * 0.55,
        y:     -20 - Math.random() * h * 0.10, // ignites just above the frame
        vx:    Math.cos(angle) * speed * (ltr ? 1 : -1),
        vy:    Math.sin(angle) * speed,
        born:  now,
        dur:   700 + Math.random() * 500,      // burns out in under ~1.2s
        scale: 1.0 + Math.random() * 0.5,
      });
    }

    // Brightness over the meteor's life: fast ignition flash, then a decaying
    // burn-out — it disappears mid-sky like it was consumed by the atmosphere.
    function meteorAlpha(u: number) {
      if (u < 0.12) return u / 0.12;
      return Math.pow(1 - (u - 0.12) / 0.88, 1.6);
    }

    function updateMeteors(now: number, dtSec: number, w: number, h: number) {
      if (nextMeteorAt === 0) {
        nextMeteorAt = now + 3000 + Math.random() * 5000; // first one 3–8s in
      }
      if (now >= nextMeteorAt) {
        if (meteors.length < 2) spawnMeteor(w, h, now);   // never more than 2
        scheduleNextMeteor(now);
      }
      if (meteors.length === 0 || !meteorSprite) return;

      const sprW = METEOR_TAIL + METEOR_PAD;
      for (let i = meteors.length - 1; i >= 0; i--) {
        const m = meteors[i];
        const u = (now - m.born) / m.dur;
        if (u >= 1 || m.x < -300 || m.x > w + 300 || m.y > h + 300) {
          meteors.splice(i, 1);
          continue;
        }
        m.x += m.vx * dtSec;
        m.y += m.vy * dtSec;

        ctx!.save();
        ctx!.translate(m.x, m.y);
        ctx!.rotate(Math.atan2(m.vy, m.vx));
        ctx!.globalAlpha = Math.max(0, Math.min(1, meteorAlpha(u)));
        // Sprite's head sits at x = METEOR_TAIL; place the head at the origin
        // so the tail trails behind the direction of travel.
        ctx!.drawImage(
          meteorSprite,
          -METEOR_TAIL * m.scale, -(METEOR_H / 2) * m.scale,
          sprW * m.scale, METEOR_H * m.scale,
        );
        ctx!.restore();
      }
      ctx!.globalAlpha = 1;
    }

    // ── Resize + frame loop ───────────────────────────────────────────────────
    function resize() {
      if (!canvas || !ctx) return;
      dpr = Math.min(window.devicePixelRatio ?? 1, 2);
      const w = window.innerWidth;
      const h = window.innerHeight;

      // Mobile browsers fire resize when the URL bar collapses/expands during
      // scroll — only the height changes. Re-seeding stars/beams there makes
      // the whole sky visibly jump to new random positions mid-scroll. So:
      //   - unchanged size  → nothing to do
      //   - height-only     → re-bake sprites/canvas, KEEP all positions
      //   - width changed   → full re-seed (real window resize / rotation)
      if (w === lastW && h === lastH) return;
      const reseed = lastW === 0 || w !== lastW;
      lastW = w; lastH = h;

      canvas.width  = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      canvas.style.width  = `${w}px`;
      canvas.style.height = `${h}px`;
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);

      // Re-bake all sprites for the new dimensions
      bakeBackground(w, h);
      bakeMeteorSprite();
      beamSprites = [];
      for (let layer = 1; layer <= LAYERS; layer++) {
        beamSprites.push(bakeBeamSprites(h, layer));
      }
      if (reseed) {
        beams = [];
        for (let layer = 1; layer <= LAYERS; layer++) {
          for (let i = 0; i < BEAMS_PER_LAYER; i++) {
            beams.push(makeBeam(w, h, layer));
          }
        }
        makeStars(w, h);
      } else {
        // Height-only: beam sprite length follows h — keep positions in sync
        for (const b of beams) b.length = h * 2.4;
      }

      // In reduced-motion mode there is no RAF loop — redraw the static frame
      // so a window resize doesn't leave the canvas permanently blank.
      if (isReduced) { ctx.drawImage(bgSprite!, 0, 0, w, h); drawStars(); }
    }

    function frame(now: number) {
      if (!canvas || !ctx) return;
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;

      // Real elapsed time for the meteor physics (clamped for tab-switch gaps)
      const dtSec = lastNow > 0 ? Math.min((now - lastNow) / 1000, 0.05) : 0.016;
      lastNow = now;

      // Everything below is drawImage() of cached bitmaps — no gradients,
      // no ctx.filter, no rasterization. Same pixels as the original code.
      ctx.drawImage(bgSprite!, 0, 0, w, h);
      drawStars();

      for (let layer = 1; layer <= LAYERS; layer++) {
        const sp = beamSprites[layer - 1];
        for (const b of beams) {
          if (b.layer !== layer) continue;
          b.y     -= b.speed;
          b.pulse += b.pulseSpeed;
          if (b.y + b.length < 0) { b.y = h + 10; b.x = Math.random() * w; }
          drawBeamSprite(b, sp.outer, sp);
        }
      }

      for (let layer = 1; layer <= LAYERS; layer++) {
        const sp = beamSprites[layer - 1];
        for (const b of beams) {
          if (b.layer !== layer) continue;
          drawBeamSprite(b, sp.core, sp);
        }
      }

      // Shooting star — drawn last so the streak passes in front of the sky
      updateMeteors(now, dtSec, w, h);

      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(frame);
    }

    // ── boot — safe to call multiple times (cancels previous loop first) ─────
    function boot() {
      // Cancel any running loop and remove the resize handler. We use
      // window.__cosmicResizeFn so that after an HMR module re-evaluation
      // the previous closure's resize reference can still be removed.
      cancelAnimationFrame(raf);
      const prevResize = (window as any).__cosmicResizeFn;
      if (prevResize) window.removeEventListener('resize', prevResize);

