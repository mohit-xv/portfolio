---
/**
 * Hero — above-the-fold. Phase 4 motion:
 *   - Wordmark / subline / CTA: CSS transition, triggered by 'cold-open-complete'
 *   - Headline h1: React island (HeroReveal) — masked line-by-line reveal
 *   - Scroll cue: fades in last
 */
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import HeroReveal from '../islands/HeroReveal.tsx';
---

<section class="hero" aria-label="Introduction">
  <div class="container">
    <!-- Wordmark — CSS reveal -->
    <p class="hero__wordmark" data-hero-reveal="0" aria-label="Mohit Singh">
      Mohit Singh
    </p>

    <!-- Headline — Motion masked reveal (React island) -->
    <HeroReveal client:load />

    <!-- Credential subline — CSS reveal -->
    <Eyebrow class="hero__subline" data-hero-reveal="0.26">
      Cloud Cost Optimisation &middot; DevOps &middot; 5&times; AWS Certified
    </Eyebrow>

    <!-- CTAs — CSS reveal -->
    <div class="hero__cta" data-hero-reveal="0.34">
      <Button href="/work/this-website">See the work</Button>
      <Button href="/contact" variant="text">Get in touch</Button>
    </div>

    <!-- Scroll cue — CSS reveal (latest) -->
    <p class="hero__scroll-cue" data-hero-reveal="0.50" aria-hidden="true">scroll</p>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--space-32);
    padding-bottom: var(--space-32);
    position: relative;
    /* Canvas lives behind everything (z-index: -1); no background needed here */
  }

  /* Keep all text content above the canvas layer */
  .hero .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    position: relative;
    z-index: 1;
  }

  /* Wordmark */
  .hero__wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--bone) 50%, transparent);
    margin-bottom: var(--space-4);
  }

  /* Subline */
  .hero__subline {
    margin-top: var(--space-2);
  }

  /* CTA row */
  .hero__cta {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }

  /* Scroll cue */
  .hero__scroll-cue {
    position: absolute;
    z-index: 1;
    bottom: var(--space-12);
    left: var(--gutter);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--bone) 25%, transparent);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  /* ── CSS-driven reveals (triggered by .is-hero-visible added by script) ──
     data-hero-reveal elements start invisible; the value is the delay in seconds. */
  [data-hero-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity   0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Scroll cue has extra translation because it's position:absolute */
  .hero__scroll-cue[data-hero-reveal] {
    transform: translateY(14px) rotate(180deg);
  }

  /* Revealed state */
  [data-hero-reveal].is-hero-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero__scroll-cue.is-hero-visible {
    transform: rotate(180deg); /* restore the rotation without the Y shift */
  }

  /* Reduced motion: skip to final state immediately */
  @media (prefers-reduced-motion: reduce) {
    [data-hero-reveal] {
      opacity: 1;
      transform: translateY(0);
      transition: none;
    }
    .hero__scroll-cue[data-hero-reveal] {
      transform: rotate(180deg);
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero {
      padding-top: var(--space-24);
      align-items: flex-start;
    }
    .hero__scroll-cue {
      display: none;
    }
    .hero__cta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-5);
    }
  }
</style>

<script>
  /**
   * Trigger CSS reveals on hero elements when the cold open completes.
   * Each [data-hero-reveal] value is a delay in seconds.
   */
  function revealHero() {
    document.querySelectorAll<HTMLElement>('[data-hero-reveal]').forEach((el) => {
      const delay = parseFloat(el.dataset.heroReveal ?? '0') * 1000;
      setTimeout(() => el.classList.add('is-hero-visible'), delay);
    });
  }

  // First visit: wait for cold open; subsequent visits: fire immediately
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const alreadyShown = sessionStorage.getItem('cold-open-shown');

  if (reduced || alreadyShown) {
    revealHero();
  } else {
    window.addEventListener('cold-open-complete', revealHero, { once: true });
  }

  // Re-run on View Transition navigation (each page load is fresh)
  document.addEventListener('astro:page-load', () => {
    // Reset and re-trigger if we're on the home hero
    const els = document.querySelectorAll('[data-hero-reveal]');
    if (els.length === 0) return;
    els.forEach(el => el.classList.remove('is-hero-visible'));
    // Brief timeout so the removal registers before re-adding
    requestAnimationFrame(() => requestAnimationFrame(revealHero));
  });
</script>
