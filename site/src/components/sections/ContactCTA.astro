---
/**
 * ContactCTA — the quiet "get in touch" line before the footer.
 * A single understated sentence, not a sales pitch.
 */
import Button from '../ui/Button.astro';
---

<section class="contact-cta section" aria-label="Get in touch">
  <div class="container">
    <div class="contact-cta__inner" data-reveal>
      <p class="contact-cta__line">
        If something looks familiar, let's talk.
      </p>
      <Button href="/contact">Get in touch</Button>
    </div>
  </div>
</section>

<style>
  .contact-cta__inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-8);
    padding: var(--space-16) 0;
    border-top: 1px solid color-mix(in srgb, var(--gold) 18%, transparent);
    flex-wrap: wrap;
  }

  .contact-cta__line {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    color: var(--bone);
    line-height: var(--leading-snug);
    max-width: 22ch;
  }

  @media (max-width: 640px) {
    .contact-cta__inner {
      flex-direction: column;
      gap: var(--space-10);
      padding: var(--space-12) 0;
    }
    .contact-cta__line {
      /* Let it fill the mobile width — cinematic closing statement */
      font-size: clamp(2rem, 9vw, 3rem);
      max-width: none;
    }
  }
</style>
