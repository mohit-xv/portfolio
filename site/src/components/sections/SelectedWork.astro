---
/**
 * Selected Work — wraps the SpineSection React island.
 *
 * All exhibit content, the S-curve spine draw, and the sticky scroll
 * pinning live inside SpineSection.tsx (Phase 4 implementation).
 *
 * IMPORTANT: overflow must NOT be hidden here — sticky positioning
 * inside the island requires an unclipped scroll ancestor.
 */
import SpineSection from '../islands/SpineSection.tsx';
---

<section class="selected-work" aria-label="Selected Work">
  <SpineSection client:visible />
</section>

<style>
  .selected-work {
    /* No overflow:hidden — sticky positioning inside SpineSection requires it */
    overflow: visible;
  }
</style>
