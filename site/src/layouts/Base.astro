---
import '../styles/global.css';
import CosmicBeams from '../components/islands/CosmicBeams.astro';
import CursorRing  from '../components/islands/CursorRing.tsx';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Cloud cost optimisation and DevOps engineering by Mohit Singh — 5× AWS Certified.',
  ogImage = '/og-default.svg',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://mohitsingh.dev');
const pageTitle = title === 'Mohit Singh'
  ? 'Mohit Singh — Cloud Cost Optimisation & DevOps'
  : `${title} — Mohit Singh`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0D0B09" />

  <!-- Primary meta -->
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noIndex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://mohitsingh.dev')} />
  <meta property="og:site_name" content="Mohit Singh" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://mohitsingh.dev')} />

  <!-- Structured data — Person -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Mohit Singh",
    "url": "https://mohitsingh.dev",
    "sameAs": [
      "https://github.com/mohit-xv",
      "https://www.credly.com/users/mohit-singh"
    ],
    "jobTitle": "Cloud Cost Optimisation Engineer",
    "knowsAbout": ["AWS", "Cloud Cost Optimisation", "DevOps", "FinOps", "Terraform", "Python"],
  })} />

  <!-- Fonts — Google Fonts (Cormorant Garamond + Space Mono) and Fontshare (General Sans) -->
  <!-- Preconnect to font origins -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" />

  <!-- Cormorant Garamond: high-contrast luxury serif, beautiful italic at 300–600 weight -->
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&display=swap"
  />

  <!-- Space Mono: regular + bold -->
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
  />

  <!-- General Sans via Fontshare (variable) -->
  <link
    rel="stylesheet"
    href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Cloudflare Turnstile — bot protection for the contact form.
       Loaded on every page so it's ready when the user navigates to /contact
       via a View Transition. Skipped in local dev (no env var set). -->
  {import.meta.env.PUBLIC_TURNSTILE_SITE_KEY && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <!-- Astro View Transitions — page-to-page morphs -->
  <ClientRouter />
</head>
<body>
  <!-- Viewport-fixed animated canvas background — persists across all scroll positions -->
  <CosmicBeams />

  <!-- Scroll progress bar — 1px gold line at viewport top, fills on scroll -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <!-- Custom cursor ring — fine-pointer (mouse) devices only -->
  <CursorRing client:load />

  <!-- Grain overlay — decorative, pointer-events none -->
  <div class="grain-layer" aria-hidden="true"></div>

  <!-- Site content -->
  <slot />
</body>

<script>
  /**
   * Section reveal — IntersectionObserver adds .is-visible to [data-reveal]
   * elements when they enter the viewport. CSS in global.css handles the
   * transition. Re-runs on View Transition navigation.
   */
  function initReveal() {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
  }

  initReveal();
  document.addEventListener('astro:page-load', initReveal);
</script>

<script>
  /**
   * Lenis smooth scroll — feeds into Motion's useScroll via native events.
   * Re-initialises on Astro View Transition navigation.
   */
  import Lenis from 'lenis';

  let lenis: InstanceType<typeof Lenis> | null = null;
  let raf = 0;

  function initLenis() {
    if (lenis) { lenis.destroy(); cancelAnimationFrame(raf); }

    // Respect prefers-reduced-motion — Lenis still fires scroll events but
    // turns off the lerp so users with vestibular disorders aren't affected.
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    lenis = new Lenis({
      duration: reduced ? 0 : 1.15,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      gestureOrientation: 'vertical',
      smoothWheel: !reduced,
      touchMultiplier: 2,
    });

    function tick(time: number) {
      lenis!.raf(time);
      raf = requestAnimationFrame(tick);
    }
    raf = requestAnimationFrame(tick);
  }

  initLenis();

  // Re-init after View Transitions navigation so smooth scroll works on each page
  document.addEventListener('astro:page-load', initLenis);
</script>

<script>
  /**
   * Scroll progress bar — sets --scroll-pct on <html> so the CSS bar grows.
   * Runs on every page; re-syncs on Astro View Transition navigation.
   */
  function initScrollProgress() {
    const update = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
      document.documentElement.style.setProperty('--scroll-pct', `${pct.toFixed(2)}%`);
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
  initScrollProgress();
  document.addEventListener('astro:page-load', initScrollProgress);
</script>

<script>
  /**
   * Cookieless analytics — fire-and-forget POST to the analytics Lambda.
   * No cookie, no fingerprinting — just page + referrer.
   * Skipped silently if PUBLIC_API_URL is not set (local dev / pre-deploy).
   */
  const apiUrl = import.meta.env.PUBLIC_API_URL;

  function trackPageView() {
    if (!apiUrl) return;
    navigator.sendBeacon(
      `${apiUrl}/api/analytics`,
      JSON.stringify({
        page:     window.location.pathname,
        referrer: document.referrer,
      }),
    );
  }

  trackPageView();
  document.addEventListener('astro:page-load', trackPageView);
</script>
</html>
